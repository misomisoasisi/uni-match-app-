generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int      @id @default(autoincrement())
  name       String
  dept       String
  char       String   // MBTI等
  tags       String   // カンマ区切り
  color      String
  feature    String   // アバターのカスタマイズ特徴
  email      String   @unique
  password   String
  gender     String?  // 男女などの性別
  bio        String?  // 自己紹介文
  university String?  // 大学名
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  hasAgreedToTerms Boolean @default(false)
  hasSeenTutorial  Boolean @default(false)

  meetToken        String?
  meetTokenExpires DateTime?

  meets1     Meet[]     @relation("UserMeets1")
  meets2     Meet[]     @relation("UserMeets2")
  textbooks  Textbook[]
  gatherings Gathering[] @relation("GatheringMembers")
  createdGatherings Gathering[] @relation("GatheringCreator")
  buyerRooms ChatRoom[]  @relation("BuyerRooms")
  sellerRooms ChatRoom[] @relation("SellerRooms")
  messages   Message[]
  notifications Notification[]
  
  posts      Post[]
  likesSent  Like[]   @relation("LikeSender")
  likesReceived Like[] @relation("LikeReceiver")
  blocksGiven Block[] @relation("Blocker")
  blocksReceived Block[] @relation("Blocked")
  reportsGiven Report[] @relation("Reporter")
  reportsReceived Report[] @relation("Reported")
}

model Textbook {
  id         Int      @id @default(autoincrement())
  title      String
  className  String
  price      String
  note       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sellerId   Int
  seller     User       @relation(fields: [sellerId], references: [id])
  chatRooms  ChatRoom[]
}

model Gathering {
  id         Int      @id @default(autoincrement())
  title      String
  date       String
  place      String
  type       String
  tags       String   // カンマ区切り
  deadline   DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  creatorId  Int?
  creator    User?    @relation("GatheringCreator", fields: [creatorId], references: [id])
  members    User[]   @relation("GatheringMembers")
}

model ChatRoom {
  id         Int      @id @default(autoincrement())
  textbookId Int?
  textbook   Textbook? @relation(fields: [textbookId], references: [id])
  
  buyerId    Int
  buyer      User     @relation("BuyerRooms", fields: [buyerId], references: [id])
  
  sellerId   Int
  seller     User     @relation("SellerRooms", fields: [sellerId], references: [id])
  
  messages   Message[]
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Message {
  id         Int      @id @default(autoincrement())
  content    String
  
  senderId   Int
  sender     User     @relation(fields: [senderId], references: [id])
  
  roomId     Int
  room       ChatRoom @relation(fields: [roomId], references: [id])
  
  createdAt  DateTime @default(now())
}

model Notification {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  type       String   // 'NEW_MESSAGE', 'GATHERING_JOIN'
  content    String
  link       String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Meet {
  id        Int      @id @default(autoincrement())
  user1Id   Int
  user1     User     @relation("UserMeets1", fields: [user1Id], references: [id])
  user2Id   Int
  user2     User     @relation("UserMeets2", fields: [user2Id], references: [id])
  createdAt DateTime @default(now())

  @@unique([user1Id, user2Id])
}

model Post {
  id        Int      @id @default(autoincrement())
  content   String
  authorId  Int
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Like {
  id         Int      @id @default(autoincrement())
  senderId   Int
  sender     User     @relation("LikeSender", fields: [senderId], references: [id])
  receiverId Int
  receiver   User     @relation("LikeReceiver", fields: [receiverId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([senderId, receiverId])
}

model Block {
  id         Int      @id @default(autoincrement())
  blockerId  Int
  blocker    User     @relation("Blocker", fields: [blockerId], references: [id])
  blockedId  Int
  blocked    User     @relation("Blocked", fields: [blockedId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([blockerId, blockedId])
}

model Report {
  id         Int      @id @default(autoincrement())
  reporterId Int
  reporter   User     @relation("Reporter", fields: [reporterId], references: [id])
  reportedId Int
  reported   User     @relation("Reported", fields: [reportedId], references: [id])
  reason     String
  createdAt  DateTime @default(now())
}
